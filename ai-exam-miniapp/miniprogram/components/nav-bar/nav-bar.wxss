.nav {
  width: 100%;
  background: transparent;
  position: relative;
  z-index: 20;
}

.nav-inner {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-left: 32rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 900;
  color: #171923;
  letter-spacing: 0;
}

.back {
  position: absolute;
  left: 42rpx;
  top: 50%;
  width: 30rpx;
  height: 30rpx;
  border-left: 5rpx solid #11141d;
  border-bottom: 5rpx solid #11141d;
  transform: translateY(-50%) rotate(45deg);
}

.capsule {
  position: absolute;
  height: 62rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .82);
  border: 1rpx solid rgba(0, 0, 0, .1);
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 18rpx;
  box-shadow: 0 6rpx 18rpx rgba(45, 52, 82, .08);
}

.dot-wrap {
  width: 52rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dot-wrap text {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #111;
}

.cap-line {
  width: 1rpx;
  height: 36rpx;
  background: #d8d8de;
}

.cap-circle {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 7rpx solid #111;
  position: relative;
}

.cap-circle::after {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 8rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #111;
}

.status-time {
  position: absolute;
  left: 78rpx;
  top: 28rpx;
  color: #000;
  font-size: 32rpx;
  font-weight: 800;
  z-index: 2;
}

.status-icons {
  position: absolute;
  right: 58rpx;
  top: 30rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  z-index: 2;
}

.signal {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
}

.signal text {
  width: 8rpx;
  border-radius: 4rpx;
  background: #000;
}

.signal text:nth-child(1) { height: 14rpx; }
.signal text:nth-child(2) { height: 22rpx; }
.signal text:nth-child(3) { height: 30rpx; }

.wifi {
  width: 30rpx;
  height: 22rpx;
  border-top: 8rpx solid #000;
  border-radius: 30rpx 30rpx 0 0;
}

.battery {
  width: 42rpx;
  height: 22rpx;
  border: 4rpx solid #000;
  border-radius: 5rpx;
  position: relative;
}

.battery::after {
  content: '';
  position: absolute;
  right: -8rpx;
  top: 5rpx;
  width: 4rpx;
  height: 10rpx;
  background: #000;
  border-radius: 2rpx;
}

.nav-inner {
  align-items: flex-end;
  padding-bottom: 10rpx;
}

.title {
  font-size: 34rpx;
  line-height: 44rpx;
}

.capsule {
  height: 60rpx;
  background: rgba(255, 255, 255, .86);
  box-shadow: 0 8rpx 22rpx rgba(30, 39, 70, .08);
}

.status-time {
  left: 68rpx;
  top: 26rpx;
}

.status-icons {
  right: 56rpx;
  top: 28rpx;
}
