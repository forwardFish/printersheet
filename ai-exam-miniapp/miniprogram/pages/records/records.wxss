.records-page {
  min-height: 100vh;
  background: #fbfcff;
  padding-bottom: 40rpx;
}
.empty,
.record {
  margin-top: 24rpx;
  padding: 28rpx;
}
.empty {
  color: #7b8499;
  text-align: center;
}
.record-title {
  color: #171923;
  font-size: 30rpx;
  font-weight: 900;
}
.record-desc {
  color: #7b8499;
  font-size: 24rpx;
  line-height: 38rpx;
  margin-top: 8rpx;
}
.record-action {
  color: #5a4bf4;
  font-size: 26rpx;
  font-weight: 900;
  margin-top: 16rpx;
}
