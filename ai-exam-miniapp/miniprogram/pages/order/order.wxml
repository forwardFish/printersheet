<view class="order-page">
  <nav-bar title="确认订单" back="{{true}}"></nav-bar>
  <view class="container">
    <view class="product-card">
      <image src="/assets/crown.png" class="product-icon" mode="aspectFit"></image>
      <view class="product-info">
        <view class="product-title">{{plan.memberName || '标准版 年度会员'}}</view>
        <view class="product-sub">有效期：{{validityText || '12个月'}}</view>
      </view>
      <view class="product-price">¥{{plan.price || '399'}}</view>
      <view class="select-dot">✓</view>
    </view>

    <view class="order-info card">
      <view class="section-title">订单信息</view>
      <view class="row"><text>商品金额</text><text>¥{{plan.price || '399'}}</text></view>
      <view class="row"><text>优惠券</text><text>- ¥0</text></view>
      <view class="divider"></view>
      <view class="pay-row"><text>实付款</text><text class="pay-price">¥{{plan.price || '399'}}</text></view>
    </view>

    <view class="pay-box card">
      <view class="section-title">支付方式</view>
      <view class="pay-method active">
        <view class="wechat-icon">●●</view>
        <text>微信支付</text><text class="recommend">推荐</text>
        <view class="pay-check">✓</view>
      </view>
      <view class="pay-method">
        <view class="balance-icon">¥</view>
        <text>余额支付</text><text class="balance-note">（余额： 0点）</text>
        <view class="empty-radio"></view>
      </view>
      <view class="safe-tip"><view class="shield">◆</view>支付安全有保障，信息仅用于支付验证</view>
    </view>

    <button class="primary-btn pay-btn" loading="{{paying}}" disabled="{{paying}}" bindtap="pay">立即支付 ¥{{plan.price || '399'}}</button>
    <view class="agreement"><text class="check-dot">✓</text>我已阅读并同意 <text>《用户协议》</text> 和 <text>《隐私政策》</text></view>
  </view>
</view>
