.order-page { min-height: 100vh; background: #fff; padding-bottom: 40rpx; }
.product-card { margin-top: 22rpx; height: 150rpx; border-radius: 18rpx; border: 2rpx solid #bcb2ff; background: linear-gradient(135deg, #fff, #fbfaff); display: flex; align-items: center; padding: 0 28rpx; position: relative; }
.product-icon { width: 92rpx; height: 74rpx; margin-right: 26rpx; background: #9e8bff; border-radius: 16rpx; padding: 10rpx; }
.product-info { flex: 1; }
.product-title { font-size: 31rpx; font-weight: 900; color: #20222b; margin-bottom: 16rpx; }
.product-sub { color: #858c9d; font-size: 26rpx; }
.product-price { font-size: 36rpx; font-weight: 900; color: #22232b; margin-right: 48rpx; }
.select-dot { position: absolute; right: 30rpx; top: 54rpx; width: 42rpx; height: 42rpx; border-radius: 50%; background: #5e51f2; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 900; }
.order-info { margin-top: 34rpx; padding: 38rpx 32rpx; border: none; box-shadow: 0 20rpx 60rpx rgba(50, 60, 100, .06); }
.pay-box { margin-top: 26rpx; padding: 38rpx 32rpx; border: none; box-shadow: 0 20rpx 60rpx rgba(50, 60, 100, .06); }
.section-title { font-size: 31rpx; font-weight: 900; color: #171922; margin-bottom: 32rpx; }
.row { display: flex; justify-content: space-between; color: #697284; font-size: 28rpx; margin-bottom: 34rpx; }
.divider { height: 1rpx; background: #eef0f4; margin: 10rpx 0 30rpx; }
.pay-row { display: flex; justify-content: space-between; font-size: 28rpx; font-weight: 900; }
.pay-price { color: #ff5a1f; font-size: 42rpx; }
.pay-method { height: 84rpx; display: flex; align-items: center; position: relative; color: #20222b; font-size: 28rpx; }
.wechat-icon { width: 42rpx; height: 42rpx; background: #15c765; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14rpx; margin-right: 20rpx; }
.balance-icon { width: 42rpx; height: 42rpx; border-radius: 50%; border: 5rpx solid #98a1b2; color: #98a1b2; display: flex; align-items: center; justify-content: center; font-weight: 900; margin-right: 20rpx; }
.recommend { margin-left: 16rpx; background: #ebe9ff; color: #5e51f2; padding: 5rpx 12rpx; font-size: 22rpx; border-radius: 6rpx; }
.pay-check { position: absolute; right: 0; width: 42rpx; height: 42rpx; background: #5e51f2; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 900; }
.empty-radio { position: absolute; right: 0; width: 42rpx; height: 42rpx; border-radius: 50%; border: 3rpx solid #c3cad6; }
.disabled { color: #788194; }
.safe-tip { height: 62rpx; border-radius: 16rpx; background: #f7f8fb; color: #8c94a5; font-size: 24rpx; display: flex; align-items: center; justify-content: center; margin-top: 22rpx; }
.pay-btn { margin-top: 44rpx; }
.agreement { text-align: center; color: #8a92a2; font-size: 24rpx; margin-top: 24rpx; }
.agreement text { color: #6052f2; }
