  text-align: center;
  white-space: normal;
  word-break: break-all;
}

.mode-chip text:first-child {
  min-width: 0;
  max-width: 100%;
}

.mode-check {
  flex: 0 0 34rpx;
  margin-left: 8rpx;
}
