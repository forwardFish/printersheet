.index-page {
  background: linear-gradient(180deg, #fbfcff 0%, #f8f9ff 45%, #ffffff 100%);
}

.index-container {
  padding-top: 8rpx;
}

.hero-card {
  width: 100%;
  height: 260rpx;
  border-radius: 22rpx;
  overflow: hidden;
  display: block;
  box-shadow: 0 18rpx 44rpx rgba(105, 91, 230, .12);
}

.points-row {
  height: 88rpx;
  margin-top: 24rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.points-left {
  display: flex;
  align-items: center;
  color: #181b25;
  font-size: 28rpx;
  font-weight: 900;
}

.coin-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  margin-right: 18rpx;
  background: linear-gradient(180deg, #7d66ff, #5547ee);
  position: relative;
}

.coin-icon::before,
.coin-icon::after {
  content: '';
  position: absolute;
  left: 5rpx;
  width: 34rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(255,255,255,.55);
}

.coin-icon::before { top: 12rpx; }
.coin-icon::after { top: 25rpx; }

.points-num {
  margin-left: 14rpx;
  font-size: 34rpx;
  color: #5a4bf4;
}

.upgrade-pill {
  min-width: 278rpx;
  height: 58rpx;
  border-radius: 999rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  color: #d96f00;
  background: linear-gradient(180deg, #fff8ea, #fff2d9);
  border: 1rpx solid #ffe0ad;
  font-size: 24rpx;
  font-weight: 800;
}

.crown-mini {
  color: #f7a917;
  font-size: 28rpx;
}

.pill-arrow {
  font-size: 36rpx;
  line-height: 1;
}

.textarea-wrap {
  height: 180rpx;
  margin-top: 22rpx;
  border-radius: 22rpx;
  border: 1rpx solid #e3e7f1;
  background: rgba(255,255,255,.94);
  padding: 28rpx 28rpx 42rpx;
  position: relative;
  box-shadow: 0 12rpx 38rpx rgba(52, 61, 99, .05);
}

.prompt-input {
  width: 100%;
  height: 110rpx;
  color: #171923;
  font-size: 28rpx;
  line-height: 42rpx;
}

.placeholder {
  color: #828ba2;
}

.counter {
  position: absolute;
  right: 26rpx;
  bottom: 22rpx;
  color: #737c91;
  font-size: 24rpx;
}

.smart-hint {
  margin: 14rpx 6rpx 0;
  color: #5d50f1;
  font-size: 24rpx;
  line-height: 34rpx;
}

.prompt-guard {
  margin: 14rpx 4rpx 0;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid #e7eaf3;
  background: #fbfcff;
}

.prompt-guard.needs_detail {
  border-color: #dfe3ef;
}

.prompt-guard.invalid {
  border-color: #ffd4bf;
  background: #fff8f4;
}

.prompt-guard-text {
  color: #6f788c;
  font-size: 24rpx;
  line-height: 34rpx;
}

.prompt-guard.invalid .prompt-guard-text {
  color: #c45c2c;
}

.suggestion-row {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.suggestion-chip {
  min-height: 58rpx;
  border-radius: 16rpx;
  border: 1rpx solid #ded9ff;
  background: #fff;
  color: #5d50f1;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 800;
  padding: 12rpx 18rpx;
}

.quick-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22rpx;
  margin-top: 22rpx;
}

.quick-card {
  height: 82rpx;
  border-radius: 18rpx;
  border: 1rpx solid #e7eaf3;
  background: rgba(255,255,255,.94);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #171923;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 32rpx rgba(50, 60, 102, .06);
}

.quick-card.active {
  border-color: #a99fff;
}

.quick-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 14rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #765cff, #5548ef);
  position: relative;
}

.cap::after {
  content: '';
  position: absolute;
  left: 9rpx;
  top: 12rpx;
  width: 20rpx;
  height: 14rpx;
  border-radius: 4rpx;
  background: #fff;
  transform: rotate(30deg);
}

.book::after {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 8rpx;
  width: 17rpx;
  height: 24rpx;
  border: 5rpx solid #fff;
  border-top: 0;
  border-radius: 4rpx;
}

.chart::before,
.chart::after {
  content: '';
  position: absolute;
  bottom: 10rpx;
  width: 6rpx;
  border-radius: 4rpx;
  background: #fff;
}

.chart::before { left: 11rpx; height: 17rpx; }
.chart::after { left: 24rpx; height: 26rpx; }

.arrow {
  color: #7f8798;
  margin-left: 16rpx;
}

.select-panel {
  margin-top: 22rpx;
  padding: 26rpx 26rpx 18rpx;
}

.select-panel.compact {
  padding-bottom: 28rpx;
}

.select-head,
.option-title {
  color: #151924;
  font-size: 30rpx;
  font-weight: 900;
}

.select-group-title {
  color: #758097;
  font-size: 25rpx;
  font-weight: 800;
  margin: 20rpx 0 12rpx;
}

.select-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx 20rpx;
}

.subject-grid {
  margin-top: 22rpx;
}

.select-option {
  height: 56rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #fbfcff, #f6f7fb);
  border: 1rpx solid #e4e8f2;
  color: #1c2130;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 700;
}

.select-option.active {
  border-color: #6655ff;
  color: #5948f4;
  font-weight: 900;
  box-shadow: inset 0 0 0 1rpx #6655ff;
}

.cost-card {
  min-height: 112rpx;
  margin-top: 22rpx;
  padding: 22rpx 28rpx;
  display: flex;
  align-items: center;
}

.doc-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #efeaff, #dcd4ff);
  margin-right: 24rpx;
  position: relative;
}

.doc-icon::after {
  content: '';
  position: absolute;
  left: 22rpx;
  top: 16rpx;
  width: 22rpx;
  height: 30rpx;
  border-radius: 3rpx;
  background: #5a4bf4;
}

.cost-copy {
  flex: 1;
}

.cost-title {
  color: #171923;
  font-size: 31rpx;
  font-weight: 900;
}

.cost-desc {
  color: #707a91;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.cost-num {
  min-width: 94rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: #f0edff;
  color: #5a4bf4;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-options {
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #737c91;
  font-size: 27rpx;
}

.more-panel {
  padding: 28rpx;
}

.mode-row {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx 22rpx;
}

.mode-chip {
  min-height: 64rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #fbfcff, #f5f6fb);
  border: 1rpx solid #e3e7f0;
  color: #596276;
  font-size: 25rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  position: relative;
}

.mode-chip.active {
  color: #5a4bf4;
  border-color: #6655ff;
  background: #fbfaff;
  font-weight: 900;
}

.mode-check {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #5a4bf4;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
  font-size: 22rpx;
}

.generate-btn {
  margin-top: 24rpx;
}

.task-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  border-radius: 22rpx;
  border: 1rpx solid #e5e8f2;
  background: rgba(255,255,255,.96);
  box-shadow: 0 14rpx 42rpx rgba(54, 62, 105, .07);
  overflow: hidden;
}

.task-list-head {
  min-height: 88rpx;
  padding: 22rpx 24rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.task-list.collapsed .task-list-head {
  padding-bottom: 22rpx;
}

.task-list-title {
  color: #171923;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 38rpx;
}

.task-list-subtitle {
  margin-top: 4rpx;
  color: #858ea2;
  font-size: 22rpx;
  line-height: 30rpx;
}

.task-head-right {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.task-list-count {
  min-width: 54rpx;
  height: 44rpx;
  border-radius: 999rpx;
  padding: 0 14rpx;
  background: #f0edff;
  color: #5a4bf4;
  font-size: 24rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.task-toggle-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f6f4ff;
  color: #5a4bf4;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.task-card {
  margin: 0 22rpx;
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-top: 1rpx solid #eef1f7;
}

.task-collapsed-row {
  min-height: 78rpx;
  margin: 0 22rpx 22rpx;
  border-top: 1rpx solid #eef1f7;
  color: #5a4bf4;
  font-size: 25rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.task-main {
  flex: 1;
  min-width: 0;
}

.task-title {
  color: #171923;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 38rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-meta,
.task-message {
  color: #7b8498;
  font-size: 22rpx;
  line-height: 32rpx;
  margin-top: 4rpx;
}

.task-progress {
  height: 8rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: #eceefa;
  overflow: hidden;
}

.task-progress-inner {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #745cff, #4f46f2);
}

.task-status {
  min-width: 96rpx;
  height: 56rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #5a4bf4;
  background: #f0edff;
  font-size: 23rpx;
  font-weight: 900;
}

.task-status.succeeded {
  color: #fff;
  background: #5a4bf4;
}

.task-status.failed {
  color: #d64242;
  background: #fff0f0;
}

.task-record-link {
  margin: 4rpx 22rpx 22rpx;
  min-height: 82rpx;
  border-radius: 18rpx;
  border: 1rpx dashed #c8c0ff;
  background: #fbfaff;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.task-record-title {
  color: #5a4bf4;
  font-size: 26rpx;
  font-weight: 900;
}

.task-record-desc {
  margin-top: 4rpx;
  color: #7f8798;
  font-size: 21rpx;
}

.task-record-arrow {
  color: #5a4bf4;
  font-size: 40rpx;
  font-weight: 900;
}

.upload-card {
  margin-top: 20rpx;
  min-height: 90rpx;
  padding: 18rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  text-align: left;
}

.upload-icon {
  color: #5a4bf4;
  font-size: 36rpx;
  margin-right: 16rpx;
}

.upload-copy {
  min-width: 0;
  flex: 1;
}

.upload-title {
  color: #273044;
  font-size: 26rpx;
  font-weight: 900;
}

.upload-desc {
  color: #7d879b;
  font-size: 20rpx;
  margin-top: 6rpx;
}

.remove-file {
  margin-left: auto;
  color: #5a4bf4;
  font-size: 24rpx;
}

.last-card {
  margin-top: 20rpx;
  padding: 22rpx 26rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.last-label,
.last-meta {
  color: #788197;
  font-size: 23rpx;
}

.last-title {
  font-size: 29rpx;
  font-weight: 900;
  color: #171923;
  margin: 6rpx 0;
}

.last-action {
  color: #5a4bf4;
  font-size: 25rpx;
  font-weight: 900;
}

.index-page {
  background:
    radial-gradient(circle at 18% 10%, rgba(109, 91, 255, .07), transparent 30%),
    radial-gradient(circle at 86% 20%, rgba(255, 223, 150, .09), transparent 24%),
    linear-gradient(180deg, #fbfcff 0%, #ffffff 64%);
  min-height: 100vh;
  height: auto;
  overflow: visible;
}

