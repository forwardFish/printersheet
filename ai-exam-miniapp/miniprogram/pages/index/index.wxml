<view class="safe-page index-page">
  <nav-bar title="AI出题小助手"></nav-bar>

  <view class="container index-container">
    <image class="hero-card" src="/assets/hero-banner.png" mode="aspectFill"></image>

    <view class="points-row card">
      <view class="points-left">
        <view class="coin-icon"></view>
        <text>剩余点数</text>
        <text class="points-num">{{points}}</text>
      </view>
      <view class="upgrade-pill" bindtap="goPackages">
        <text class="crown-mini">♛</text>
        <text>升级获取更多点数</text>
        <text class="pill-arrow">›</text>
      </view>
    </view>

    <view class="textarea-wrap {{statusType === 'error' ? 'error' : ''}}">
      <textarea
        class="prompt-input"
        maxlength="300"
        value="{{prompt}}"
        bindinput="onPromptInput"
        placeholder="例如：生成 5 道初一数学一元一次方程中等题，带答案解析，适合打印。"
        placeholder-class="placeholder"
        auto-height="false"
        disabled="{{loading}}"
      ></textarea>
      <view class="counter">{{prompt.length}}/300</view>
    </view>

    <view wx:if="{{smartHint}}" class="smart-hint">{{smartHint}}</view>

    <view wx:if="{{promptGuardMessage}}" class="prompt-guard {{promptGuardState}}">
      <view class="prompt-guard-text">{{promptGuardMessage}}</view>
      <view wx:if="{{promptSuggestions.length}}" class="suggestion-row">
        <view
          wx:for="{{promptSuggestions}}"
          wx:key="*this"
          class="suggestion-chip"
          data-prompt="{{item}}"
          bindtap="applyPromptSuggestion"
        >{{item}}</view>
      </view>
    </view>

    <view class="quick-row">
      <view class="quick-card {{openDropdown==='grade' ? 'active' : ''}}" bindtap="chooseGrade">
        <view class="quick-icon cap"></view>
        <text>{{grade}}</text>
        <text class="arrow">⌄</text>
      </view>
      <view class="quick-card {{openDropdown==='subject' ? 'active' : ''}}" bindtap="chooseSubject">
        <view class="quick-icon book"></view>
        <text>{{subject}}</text>
        <text class="arrow">⌄</text>
      </view>
      <view class="quick-card" bindtap="chooseDifficulty">
        <view class="quick-icon chart"></view>
        <text>{{difficulty}}</text>
        <text class="arrow">⌄</text>
      </view>
    </view>

    <view wx:if="{{openDropdown === 'grade'}}" class="select-panel card">
      <view class="select-head">选择年级</view>
      <view wx:for="{{gradeGroups}}" wx:for-item="group" wx:key="name" class="select-group">
        <view class="select-group-title">{{group.name}}</view>
        <view class="select-grid">
          <view
            wx:for="{{group.items}}"
            wx:for-item="gradeItem"
            wx:key="*this"
            class="select-option {{grade===gradeItem ? 'active' : ''}}"
            data-value="{{gradeItem}}"
            bindtap="selectGrade"
          >{{gradeItem}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{openDropdown === 'subject'}}" class="select-panel card compact">
      <view class="select-head">选择学科</view>
      <view class="select-grid subject-grid">
        <view
          wx:for="{{subjectOptions}}"
          wx:key="*this"
          class="select-option {{subject===item ? 'active' : ''}}"
          data-value="{{item}}"
          bindtap="selectSubject"
        >{{item}}</view>
      </view>
    </view>

    <view class="cost-card card">
      <view class="doc-icon"></view>
      <view class="cost-copy">
        <view class="cost-title">{{currentModeLabel}}</view>
        <view class="cost-desc">{{currentModeDesc}}</view>
      </view>
      <view class="cost-num">{{currentModeCost}} 点</view>
    </view>

    <view class="more-options" bindtap="toggleMore">
      <text>更多选项</text>
      <text class="down">{{showMore ? '⌃' : '⌄'}}</text>
    </view>

    <view wx:if="{{showMore}}" class="more-panel card">
      <view class="option-title">生成类型</view>
      <view class="mode-row">
        <view
          wx:for="{{generationModes}}"
          wx:key="id"
          class="mode-chip {{mode===item.id?'active':''}}"
          data-mode="{{item.id}}"
          bindtap="selectMode"
        >
          <text>{{item.shortLabel}} · {{item.cost}}点</text>
          <text wx:if="{{mode===item.id}}" class="mode-check">✓</text>
        </view>
      </view>
    </view>

    <button
      class="primary-btn generate-btn {{loading || !canGenerate || queueFull || duplicateGenerationLocked ? 'disabled' : ''}}"
      loading="{{loading}}"
      disabled="{{loading || !canGenerate || queueFull || duplicateGenerationLocked}}"
      bindtap="handleGenerate"
    >{{submitButtonText || generateButtonText}}</button>

    <view class="upload-card card {{filePath ? 'selected' : ''}}" bindtap="chooseFile">
      <view class="upload-icon">↥</view>
      <view class="upload-copy">
        <view class="upload-title">{{fileName || '上传资料（PDF / Word / 图片）'}}</view>
        <view class="upload-desc">{{filePath ? '已选择资料，可用于生成或整卷仿真。' : '支持 PDF、Word、图片，最多上传 10MB'}}</view>
      </view>
      <view wx:if="{{filePath}}" class="remove-file" catchtap="removeFile">移除</view>
    </view>

    <view wx:if="{{generationTasks.length}}" class="task-list {{recentGenerationCollapsed ? 'collapsed' : ''}}">
      <view class="task-list-head" bindtap="toggleRecentGeneration">
        <view>
          <view class="task-list-title">最近生成</view>
          <view class="task-list-subtitle">{{recentGenerationCollapsed ? '已收起，点击展开最近生成。' : '最多展示 3 条，完整内容在生成记录里查看。'}}</view>
        </view>
        <view class="task-head-right">
          <view class="task-list-count">{{generationTasks.length}}</view>
          <view class="task-toggle-icon">{{recentGenerationCollapsed ? '⌄' : '⌃'}}</view>
        </view>
      </view>
      <view wx:if="{{!recentGenerationCollapsed}}" class="task-list-body">
        <view
          wx:for="{{visibleGenerationTasks}}"
          wx:key="id"
          class="task-card {{item.status}}"
          data-id="{{item.id}}"
          bindtap="previewGenerationTask"
        >
          <view class="task-main">
            <view class="task-title">{{item.prompt || item.modeLabel}}</view>
            <view class="task-meta">{{item.grade}} · {{item.subject}} · {{item.modeLabel}}</view>
            <view class="task-message">{{item.message || (item.status === 'succeeded' ? '生成完成，点击预览。' : '正在生成，可离开页面。')}}</view>
            <view wx:if="{{item.status === 'queued' || item.status === 'running'}}" class="task-progress">
              <view class="task-progress-inner" style="width: {{item.progress || 8}}%;"></view>
            </view>
          </view>
          <view class="task-status {{item.status}}">
            {{item.status === 'succeeded' ? '去预览' : item.status === 'failed' ? '失败' : '生成中'}}
          </view>
        </view>
        <view wx:if="{{hasMoreGenerationTasks}}" class="task-record-link" bindtap="goGenerationRecords">
          <view>
            <view class="task-record-title">生成记录</view>
            <view class="task-record-desc">还有 {{hiddenGenerationTaskCount}} 条，查看全部生成内容</view>
          </view>
          <view class="task-record-arrow">›</view>
        </view>
      </view>
      <view wx:else class="task-collapsed-row" bindtap="goGenerationRecords">
        <text>查看全部生成记录</text>
        <text class="task-record-arrow">›</text>
      </view>
    </view>

    <view wx:if="{{hasLastWorksheet}}" class="last-card card" bindtap="goPreview">
      <view>
        <view class="last-label">最近生成</view>
        <view class="last-title">{{lastWorksheetTitle}}</view>
        <view class="last-meta">{{lastWorksheetMeta}}</view>
      </view>
      <view class="last-action">去预览</view>
    </view>
  </view>

  <bottom-tab active="home"></bottom-tab>
</view>
