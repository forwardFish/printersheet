.preview-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fbfcff 0%, #ffffff 100%);
  padding-bottom: 44rpx;
}

.tabs {
  height: 74rpx;
  margin-top: 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e2e6f0;
  background: #fff;
  display: grid;
  grid-template-columns: 1fr 1fr;
  overflow: hidden;
}

.tab {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #171923;
  font-size: 30rpx;
  font-weight: 800;
}

.tab.active {
  color: #5a4bf4;
  border: 2rpx solid #6655ff;
  border-radius: 16rpx;
  background: #fbfaff;
}

.paper-card {
  margin-top: 26rpx;
  padding: 44rpx 54rpx 30rpx;
  min-height: 970rpx;
  color: #111;
  border-radius: 20rpx;
  box-shadow: 0 20rpx 60rpx rgba(47, 56, 94, .08);
}

.paper-title {
  text-align: center;
  color: #111;
  font-size: 34rpx;
  font-weight: 900;
  margin-bottom: 38rpx;
}

.paper-meta {
  display: flex;
  justify-content: space-between;
  color: #111;
  font-size: 22rpx;
  margin-bottom: 34rpx;
}

.paper-section {
  margin-top: 18rpx;
}

.section-name {
  color: #111;
  font-size: 24rpx;
  font-weight: 900;
  margin-bottom: 18rpx;
}

.question {
  color: #111;
  font-size: 22rpx;
  line-height: 38rpx;
  margin-bottom: 16rpx;
}

.options {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8rpx 46rpx;
  padding-left: 36rpx;
  margin-top: 8rpx;
}

.diagram-box {
  width: 360rpx;
  height: 220rpx;
  margin: 16rpx 0 10rpx 42rpx;
  position: relative;
}

.geometry-diagram,
.number-line-diagram {
  width: 100%;
  height: 100%;
  position: relative;
}

.diagram-segment {
  position: absolute;
  height: 3rpx;
  background: #111;
  transform-origin: 0 50%;
}

.diagram-label,
.diagram-length {
  position: absolute;
  transform: translate(-50%, -50%);
  color: #111;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1;
}

.diagram-length {
  font-size: 20rpx;
  background: #fff;
  padding: 0 6rpx;
}

.diagram-right-mark {
  position: absolute;
  width: 22rpx;
  height: 22rpx;
  border-left: 3rpx solid #111;
  border-top: 3rpx solid #111;
  transform: translate(4rpx, -26rpx);
}

.number-line-axis {
  position: absolute;
  left: 0;
  right: 0;
  top: 48%;
  height: 3rpx;
  background: #111;
}

.number-line-tick,
.number-line-point {
  position: absolute;
  top: 48%;
  transform: translateX(-50%);
  color: #111;
  font-size: 19rpx;
}

.number-line-tick::before,
.number-line-point::before {
  content: '';
  display: block;
  width: 2rpx;
  height: 18rpx;
  margin: -8rpx auto 6rpx;
  background: #111;
}

.number-line-point::before {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-top: -5rpx;
}

.answer-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef0f5;
}

.answer-head {
  font-size: 24rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.answer-body {
  margin-top: 10rpx;
  color: #5b6577;
  font-size: 22rpx;
  line-height: 36rpx;
}

.page-index {
  margin: 24rpx auto 0;
  padding-top: 22rpx;
  width: 520rpx;
  border-top: 1rpx solid #dfe3eb;
  text-align: center;
  color: #7a8395;
  font-size: 24rpx;
  line-height: 34rpx;
}

.download-row {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.download-card {
  height: 96rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  padding: 0 34rpx;
  text-align: left;
  position: relative;
}

.download-icon {
  width: 58rpx;
  height: 58rpx;
  margin-right: 24rpx;
}

.download-title {
  color: #171923;
  font-size: 28rpx;
  font-weight: 900;
}

.download-sub {
  color: #6f788c;
  font-size: 23rpx;
  margin-top: 4rpx;
}

.lock {
  margin-left: auto;
  color: #7e8799;
}

.regen {
  height: 82rpx;
  margin-top: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #171923;
  font-size: 28rpx;
  font-weight: 800;
}

.upgrade-card {
  height: 120rpx;
  margin-top: 26rpx;
  border-radius: 18rpx;
  border: 1rpx solid #f4d79b;
  background: linear-gradient(135deg, #fff9ec, #fffdf8);
  display: flex;
  align-items: center;
  padding: 0 28rpx;
}

.upgrade-crown {
  width: 72rpx;
  height: 72rpx;
  margin-right: 26rpx;
}

.upgrade-copy {
  flex: 1;
}

.upgrade-copy view {
  color: #d77b00;
  font-size: 30rpx;
  font-weight: 900;
}

.upgrade-copy text {
  color: #6d7689;
  font-size: 24rpx;
  margin-top: 8rpx;
  display: block;
}

.upgrade-card button {
  width: 142rpx;
  height: 66rpx;
  border-radius: 12rpx;
  color: #fff;
  background: linear-gradient(135deg, #6b55ff, #5548ef);
  font-size: 27rpx;
  font-weight: 900;
}

.inline-status {
  color: #5a4bf4;
  text-align: center;
  margin-top: 18rpx;
  font-size: 24rpx;
}

.preview-page {
  background:
    radial-gradient(circle at 22% 8%, rgba(95, 78, 240, .055), transparent 30%),
    linear-gradient(180deg, #fbfcff 0%, #ffffff 68%);
}

.tabs {
  height: 78rpx;
  margin-top: 26rpx;
  border-radius: 18rpx;
}

.tab {
  font-size: 31rpx;
}

.paper-card {
  min-height: 980rpx;
  border-radius: 22rpx;
  padding: 48rpx 58rpx 34rpx;
}

.paper-title {
  font-size: 36rpx;
  line-height: 48rpx;
}

.paper-meta {
  font-size: 23rpx;
  margin-bottom: 36rpx;
}

.section-name {
  font-size: 25rpx;
}

.question {
  font-size: 23rpx;
  line-height: 40rpx;
}

.download-card {
  height: 104rpx;
  border-radius: 18rpx;
}

.download-icon {
  width: 64rpx;
  height: 64rpx;
}

.regen {
  height: 86rpx;
}

.upgrade-card {
  height: 126rpx;
  border-radius: 20rpx;
}
