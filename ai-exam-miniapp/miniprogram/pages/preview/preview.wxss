.preview-page { min-height: 100vh; background: #f7f8fb; padding-bottom: 60rpx; }
.status-card {
  min-height: 72rpx;
  border-radius: 16rpx;
  padding: 18rpx 22rpx;
  margin: 20rpx 0;
  display: flex;
  align-items: center;
  background: #f3f6ff;
  color: #596276;
  font-size: 24rpx;
  line-height: 1.45;
}
.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #7d8aa3;
  margin-right: 14rpx;
  flex-shrink: 0;
}
.status-card.ready .status-dot { background: #2fb36f; }
.status-card.loading .status-dot { background: #5a4bf4; }
.status-card.error {
  background: #fff2f2;
  color: #b53333;
}
.status-card.error .status-dot { background: #e34f4f; }
.empty-card {
  padding: 44rpx 34rpx;
  text-align: center;
  margin-top: 36rpx;
}
.empty-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #161820;
  margin-bottom: 14rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #6f7788;
  line-height: 1.6;
  margin-bottom: 30rpx;
}
.empty-btn { height: 86rpx; }
.preview-summary {
  border-radius: 22rpx;
  padding: 26rpx;
  background: linear-gradient(135deg, #eff7ff 0%, #ffffff 70%);
  border: 1rpx solid #dceaff;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.preview-summary.simulation {
  background: linear-gradient(135deg, #fff6e7 0%, #ffffff 72%);
  border-color: #ffe2aa;
}
.mode-badge {
  display: inline-flex;
  height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  align-items: center;
  background: #e8f1ff;
  color: #2366b8;
  font-size: 22rpx;
  font-weight: 800;
}
.simulation .mode-badge {
  background: #ffedc7;
  color: #b66b12;
}
.summary-title {
  font-size: 34rpx;
  color: #15151d;
  font-weight: 900;
  margin-top: 16rpx;
  line-height: 1.28;
}
.summary-desc {
  color: #687183;
  font-size: 24rpx;
  line-height: 1.45;
  margin-top: 8rpx;
}
.summary-count {
  min-width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: #fff;
  color: #15151d;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 28rpx rgba(45, 62, 95, .08);
  margin-left: 18rpx;
}
.source-card {
  border-radius: 18rpx;
  background: #fff;
  border: 1rpx solid #edf0f7;
  padding: 20rpx 24rpx;
  margin-top: 18rpx;
}
.source-title {
  color: #20222b;
  font-size: 25rpx;
  font-weight: 800;
}
.source-notice {
  color: #7a8292;
  font-size: 23rpx;
  line-height: 1.5;
  margin-top: 8rpx;
}
.blueprint-card {
  padding: 24rpx;
  margin-top: 18rpx;
}
.blueprint-title {
  color: #171922;
  font-size: 27rpx;
  font-weight: 900;
}
.blueprint-row {
  display: flex;
  gap: 12rpx;
  margin: 18rpx 0 8rpx;
}
.blueprint-row text {
  flex: 1;
  height: 54rpx;
  border-radius: 12rpx;
  background: #fff8ec;
  color: #9d641a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 800;
}
.blueprint-section {
  display: flex;
  justify-content: space-between;
  color: #626b7d;
  font-size: 23rpx;
  padding-top: 12rpx;
}
.tabs {
  display: flex;
  height: 76rpx;
  align-items: center;
  justify-content: space-between;
  margin: 20rpx 0 26rpx;
}
.tab {
  width: 48%;
  height: 74rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 29rpx;
  font-weight: 700;
  color: #15151d;
}
.tab.active {
  color: #5a4bf4;
  border: 2rpx solid #aaa2ff;
  background: linear-gradient(180deg, #f6f5ff 0%, #ffffff 100%);
}
.paper {
  min-height: 820rpx;
  padding: 48rpx 52rpx 36rpx;
  border-color: #e5e8f0;
  box-shadow: 0 20rpx 50rpx rgba(60, 68, 112, .09);
}
.simulation-paper {
  border-color: #f2d397;
}
.paper-head {
  padding-bottom: 26rpx;
  border-bottom: 2rpx solid #20222b;
  margin-bottom: 28rpx;
}
.paper-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 900;
  color: #15151d;
  margin-bottom: 12rpx;
  line-height: 1.35;
}
.paper-subtitle {
  text-align: center;
  color: #737b8f;
  font-size: 23rpx;
  font-weight: 700;
}
.paper-meta {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 28rpx;
  font-size: 24rpx;
  color: #1d1f2a;
  font-weight: 600;
  margin-bottom: 34rpx;
}
.section-title {
  font-size: 26rpx;
  font-weight: 900;
  margin: 28rpx 0 20rpx;
  color: #191a22;
  display: flex;
  justify-content: space-between;
}
.section-title text:last-child {
  color: #747d90;
  font-size: 22rpx;
  font-weight: 700;
}
.question {
  margin-bottom: 34rpx;
  color: #161820;
  break-inside: avoid;
}
.q-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 10rpx;
}
.q-meta text {
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #f1f3f8;
  color: #697286;
  font-size: 20rpx;
  font-weight: 700;
}
.q-title {
  font-size: 25rpx;
  line-height: 1.85;
  font-weight: 600;
}
.q-number {
  font-weight: 900;
  margin-right: 8rpx;
}
.prose-inline {
  color: inherit;
}
.latex-inline {
  display: inline-flex;
  max-width: 100%;
  min-height: 38rpx;
  align-items: center;
  margin: 0 6rpx 6rpx;
  padding: 0 10rpx;
  border-radius: 8rpx;
  background: #f3f6ff;
  color: #25315c;
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
  font-size: 24rpx;
  font-weight: 800;
  vertical-align: middle;
  box-sizing: border-box;
}
.options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  column-gap: 22rpx;
  row-gap: 18rpx;
  padding: 18rpx 0 0 32rpx;
}
.option {
  font-size: 24rpx;
  color: #171922;
}
.mini-table {
  margin: 16rpx 0 6rpx 32rpx;
  border: 1rpx solid #dfe5ef;
  border-radius: 10rpx;
  overflow: hidden;
}
.mini-table-row {
  display: flex;
  min-height: 50rpx;
  border-top: 1rpx solid #e8ecf4;
}
.mini-table-row:first-child {
  border-top: 0;
}
.mini-table-row.head {
  background: #f4f7fb;
  color: #202532;
  font-weight: 900;
}
.mini-table-row text {
  flex: 1;
  min-width: 0;
  padding: 12rpx 10rpx;
  border-left: 1rpx solid #e8ecf4;
  text-align: center;
  color: #333a49;
  font-size: 22rpx;
  line-height: 1.3;
}
.mini-table-row text:first-child {
  border-left: 0;
}
.diagram-card {
  position: relative;
  margin: 18rpx 0 8rpx 32rpx;
  height: 210rpx;
  border-radius: 12rpx;
  background: #fbfcff;
  border: 1rpx solid #e2e7f0;
  overflow: hidden;
}
.number-line-card {
  height: 150rpx;
}
.number-axis {
  position: absolute;
  left: 8%;
  right: 8%;
  top: 74rpx;
  height: 3rpx;
  background: #252a36;
}
.number-tick,
.number-point {
  position: absolute;
  top: 62rpx;
  transform: translateX(-50%);
  text-align: center;
}
.tick-mark {
  width: 2rpx;
  height: 24rpx;
  margin: 0 auto 8rpx;
  background: #252a36;
}
.number-tick text {
  color: #687183;
  font-size: 20rpx;
}
.number-point {
  top: 34rpx;
}
.point-dot {
  width: 15rpx;
  height: 15rpx;
  border-radius: 50%;
  margin: 24rpx auto 4rpx;
  background: #5a4bf4;
}
.number-point text {
  color: #2d3450;
  font-size: 22rpx;
  font-weight: 900;
}
.geometry-card {
  height: 230rpx;
}
.geometry-line {
  position: absolute;
  height: 3rpx;
  background: #202532;
  transform-origin: 0 50%;
}
.geometry-label {
  position: absolute;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: #fff;
  color: #27314f;
  border: 1rpx solid #cad2e2;
  text-align: center;
  font-size: 20rpx;
  font-weight: 900;
}
.blank-wrap {
  padding-top: 10rpx;
}
.blank-line {
  height: 48rpx;
  border-bottom: 1rpx solid #d4d8e3;
}
.page-index {
  text-align: center;
  color: #737b8f;
  font-size: 26rpx;
  margin-top: 28rpx;
}
.paper-note {
  margin-top: 28rpx;
  padding: 18rpx 20rpx;
  background: #f7f8fb;
  color: #6c7485;
  border-radius: 12rpx;
  font-size: 23rpx;
  line-height: 1.5;
}
.answer-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eff1f5;
}
.answer-title {
  font-size: 27rpx;
  color: #171922;
  margin-bottom: 14rpx;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}
.answer-main {
  flex: 1;
  min-width: 0;
  line-height: 1.75;
}
.answer-number {
  font-weight: 900;
  margin-right: 8rpx;
}
.answer-label {
  display: inline-flex;
  height: 38rpx;
  padding: 0 12rpx;
  border-radius: 10rpx;
  background: #effaf5;
  color: #178451;
  align-items: center;
  font-size: 23rpx;
  font-weight: 900;
  margin-right: 10rpx;
}
.answer-math {
  background: #fff7e8;
  color: #8d5511;
}
.answer-toggle {
  color: #5a4bf4;
  font-size: 23rpx;
  flex-shrink: 0;
  padding-top: 6rpx;
}
.explain-box {
  border-radius: 16rpx;
  background: #f8fafc;
  border: 1rpx solid #edf1f7;
  padding: 20rpx;
}
.explain-head {
  color: #171922;
  font-size: 25rpx;
  font-weight: 900;
  margin-bottom: 14rpx;
}
.explain-step {
  padding: 14rpx 0;
  border-top: 1rpx solid #edf1f7;
}
.explain-step:first-of-type {
  border-top: 0;
  padding-top: 0;
}
.step-content {
  color: #5f6778;
  font-size: 25rpx;
  line-height: 1.85;
}
.action-panel {
  border-radius: 22rpx;
  background: #fff;
  border: 1rpx solid #e6eaf2;
  padding: 24rpx;
  margin: 26rpx 0 18rpx;
  box-shadow: 0 18rpx 44rpx rgba(41, 50, 82, .07);
}
.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
}
.panel-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #171922;
  line-height: 1.2;
}
.panel-subtitle {
  margin-top: 8rpx;
  color: #7c8495;
  font-size: 23rpx;
}
.panel-pill {
  flex: 0 0 auto;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  background: #f4f1ff;
  color: #5a4bf4;
  display: flex;
  align-items: center;
  font-size: 23rpx;
  font-weight: 800;
}
.export-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.export-tile {
  min-width: 0;
  height: 118rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #eef1f6;
  display: flex;
  align-items: center;
  padding: 0 18rpx;
}
.export-tile.busy {
  opacity: .68;
}
.export-tile.locked {
  background: #fbfbfd;
}
.export-icon {
  flex: 0 0 58rpx;
  width: 58rpx;
  height: 58rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}
.export-icon.pdf {
  background: #fff1f4;
}
.export-icon.word {
  background: #eef5ff;
}
.export-icon image {
  width: 42rpx;
  height: 42rpx;
}
.export-copy {
  min-width: 0;
  flex: 1;
}
.export-title {
  color: #171922;
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.export-desc {
  margin-top: 8rpx;
  color: #7d8698;
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.mini-lock {
  flex: 0 0 42rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #eef0f5;
  color: #80889a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 21rpx;
  font-weight: 900;
  margin-left: 8rpx;
}
.inline-status {
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  background: #f7f8fb;
  color: #626b7d;
  font-size: 23rpx;
  line-height: 1.45;
}
.reward-strip {
  margin-top: 18rpx;
  min-height: 96rpx;
  border-radius: 18rpx;
  background: linear-gradient(90deg, #fff9ed 0%, #fff 72%);
  border: 1rpx solid #f5e3bd;
  display: flex;
  align-items: center;
  padding: 16rpx;
}
.reward-mark {
  flex: 0 0 54rpx;
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
  background: #ffd66b;
  color: #8b5700;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 900;
  margin-right: 16rpx;
}
.reward-copy {
  flex: 1;
  min-width: 0;
}
.reward-title {
  color: #171922;
  font-size: 27rpx;
  line-height: 1.2;
  font-weight: 900;
}
.reward-desc {
  margin-top: 8rpx;
  color: #8b7351;
  font-size: 22rpx;
  line-height: 1.35;
}
.reward-actions {
  flex: 0 0 auto;
  display: flex;
  gap: 10rpx;
  margin-left: 14rpx;
}
.mini-btn {
  width: 132rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 14rpx;
  font-size: 23rpx;
  font-weight: 900;
  padding: 0;
}
.mini-btn::after {
  border: 0;
}
.mini-btn.ghost {
  background: #fff;
  color: #5a4bf4;
  border: 1rpx solid #ddd8ff;
}
.mini-btn.primary {
  background: #5a4bf4;
  color: #fff;
}
.invite-row {
  height: 70rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  margin-top: 16rpx;
}
.invite-row text:first-child {
  color: #171922;
  font-size: 25rpx;
  font-weight: 900;
}
.invite-row text:last-child {
  color: #7d8698;
  font-size: 22rpx;
}
.regen-btn {
  width: 100%;
  height: 84rpx;
  border-radius: 18rpx;
  border: 1rpx solid #e5e8f0;
  background: #fff;
  color: #171922;
  font-size: 28rpx;
  font-weight: 900;
  margin: 0 0 18rpx;
}
.regen-btn::after {
  border: 0;
}
.upgrade-card {
  min-height: 112rpx;
  border-radius: 20rpx;
  background: linear-gradient(90deg, #fff7e7 0%, #fffdf6 100%);
  border: 1rpx solid #f6d795;
  display: flex;
  align-items: center;
  padding: 20rpx 22rpx;
}
.crown { width: 74rpx; height: 60rpx; margin-right: 18rpx; }
.upgrade-copy { flex: 1; }
.upgrade-title { font-size: 28rpx; font-weight: 800; color: #e47a18; margin-bottom: 7rpx; }
.upgrade-desc { color: #7b6f60; font-size: 22rpx; line-height: 1.35; }
.upgrade-btn {
  width: 148rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #6b55ff, #5548f0);
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
  padding: 0;
}
.upgrade-btn::after {
  border: 0;
}
