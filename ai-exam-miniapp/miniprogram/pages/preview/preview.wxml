<view class="preview-page">
  <nav-bar title="练习卷预览" back="{{true}}"></nav-bar>
  <view class="container">
    <view class="tabs">
      <view class="tab {{tab==='student'?'active':''}}" data-tab="student" bindtap="switchTab">学生练习版</view>
      <view class="tab {{tab==='answer'?'active':''}}" data-tab="answer" bindtap="switchTab">答案解析版</view>
    </view>

    <view class="paper-card card">
      <view class="paper-title">{{worksheet.title}}</view>
      <view class="paper-meta">
        <text>班级：__________</text>
        <text>姓名：__________</text>
        <text>得分：__________</text>
      </view>

      <block wx:if="{{tab==='student'}}">
        <view wx:for="{{sections}}" wx:key="name" class="paper-section">
          <view class="section-name">{{item.name}}</view>
          <view wx:for="{{item.questions}}" wx:for-item="q" wx:key="number" class="question">
            <view class="stem">{{q.number}}. {{q.displayQuestion ? q.displayQuestion : q.question}}</view>
            <view wx:if="{{q.diagramView}}" class="diagram-box">
              <view wx:if="{{q.diagramView.type==='geometry'}}" class="geometry-diagram">
                <view wx:for="{{q.diagramView.segments}}" wx:for-item="seg" wx:key="id" class="diagram-segment" style="{{seg.style}}"></view>
                <view wx:for="{{q.diagramView.marks}}" wx:for-item="mark" wx:key="id" class="diagram-right-mark" style="{{mark.style}}"></view>
                <view wx:for="{{q.diagramView.labels}}" wx:for-item="label" wx:key="id" class="diagram-label" style="{{label.style}}">{{label.label}}</view>
                <view wx:for="{{q.diagramView.lengthLabels}}" wx:for-item="len" wx:key="id" class="diagram-length" style="{{len.style}}">{{len.text}}</view>
              </view>
              <view wx:elif="{{q.diagramView.type==='number_line'}}" class="number-line-diagram">
                <view class="number-line-axis"></view>
                <view wx:for="{{q.diagramView.ticks}}" wx:for-item="tick" wx:key="id" class="number-line-tick" style="left:{{tick.left}}"><text>{{tick.label}}</text></view>
                <view wx:for="{{q.diagramView.labels}}" wx:for-item="label" wx:key="id" class="number-line-point" style="left:{{label.left}}"><text>{{label.label}}</text></view>
              </view>
            </view>
            <view wx:if="{{q.options.length}}" class="options">
              <text wx:for="{{q.options}}" wx:for-item="op" wx:key="*this">{{op}}</text>
            </view>
          </view>
        </view>
      </block>

      <block wx:else>
        <view wx:for="{{answerItems}}" wx:key="number" class="answer-item" data-number="{{item.number}}" bindtap="toggleAnswer">
          <view class="answer-head">{{item.number}}. {{item.displayQuestion ? item.displayQuestion : item.question}}</view>
          <view wx:if="{{item.expanded}}" class="answer-body">答案：{{item.answer}}。解析：{{item.explanation}}</view>
        </view>
      </block>

      <view class="page-index">预览示意，完整分页请下载 PDF 查看</view>
    </view>

    <view class="download-row">
      <button class="download-card card" loading="{{exportLoading==='pdf'}}" bindtap="openPdf">
        <image src="/assets/pdf.png" class="download-icon"></image>
        <view><view class="download-title">下载 PDF</view><view class="download-sub">{{canRemoveWatermark ? '（无水印）' : '（带水印）'}}</view></view>
      </button>
      <button class="download-card card" loading="{{exportLoading==='word'}}" bindtap="openWord">
        <image src="/assets/word.png" class="download-icon"></image>
        <view><view class="download-title">下载 Word</view><view class="download-sub">（可编辑）</view></view>
        <view wx:if="{{!canDownloadWord}}" class="lock">▣</view>
      </button>
    </view>

    <button class="regen card" loading="{{loading}}" bindtap="regenerate">↻ 重新生成</button>

    <view wx:if="{{!isPaid}}" class="upgrade-card">
      <image src="/assets/crown.png" class="upgrade-crown"></image>
      <view class="upgrade-copy">
        <view>升级会员</view>
        <text>下载无水印、Word 可编辑、答案解析等更多权益</text>
      </view>
      <button bindtap="goPackages">去升级</button>
    </view>

    <view wx:if="{{exportStatusText}}" class="inline-status">{{exportStatusText}}</view>
    <view wx:if="{{shareStatusText}}" class="inline-status">{{shareStatusText}}</view>
  </view>
</view>
