<view class="packages-page">
  <nav-bar title="选择套餐" back="{{true}}"></nav-bar>
  <view class="container">
    <view class="top-card">
      <view class="top-copy">
        <view class="top-title">购买套餐或点数包</view>
        <view class="top-desc">PDF 下载不扣点；Pro / Teacher 支持 Word；整卷仿真固定 10 点</view>
      </view>
      <image src="/assets/crown.png" class="top-crown" mode="aspectFit"></image>
    </view>

    <view class="plan-card free-card card">
      <view class="plan-head">
        <view class="plan-name">{{freePlan.name}}</view>
        <view class="tag default">默认</view>
      </view>
      <view class="price-row"><text class="yen">¥</text><text class="price">{{freePlan.price}}</text><text class="period"> /{{freePlan.billingLabel}}</text></view>
      <view class="benefits">
        <view wx:for="{{freePlan.benefits}}" wx:for-item="b" wx:key="*this" class="benefit"><text>✓</text>{{b}}</view>
      </view>
    </view>

    <view wx:for="{{plans}}" wx:key="id" class="plan-card card {{selectedId===item.id?'selected':''}}" data-id="{{item.id}}" bindtap="selectPlan">
      <view class="plan-head">
        <view class="plan-name {{selectedId===item.id?'blue':''}}">{{item.name}}</view>
        <view wx:if="{{item.recommend}}" class="tag">推荐</view>
      </view>
      <view class="price-row">
        <text class="yen">¥</text><text class="price">{{item.price}}</text><text class="period"> /{{item.billingLabel}}</text>
      </view>
      <view class="benefits">
        <view wx:for="{{item.benefits}}" wx:for-item="b" wx:key="*this" class="benefit"><text>✓</text>{{b}}</view>
      </view>
      <view class="radio {{selectedId===item.id?'checked':''}}">{{selectedId===item.id?'✓':''}}</view>
    </view>

    <button class="primary-btn upgrade-main" bindtap="goOrder">立即购买</button>
  </view>
</view>
