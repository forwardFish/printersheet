.packages-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fbfcff 0%, #ffffff 100%);
  padding-bottom: 48rpx;
}

.top-card {
  height: 224rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #6e4fff 0%, #584af1 100%);
  color: #fff;
  padding: 34rpx;
  display: flex;
  justify-content: space-between;
  overflow: hidden;
  margin: 22rpx 0 26rpx;
  position: relative;
}

.top-card::after {
  content: '';
  position: absolute;
  right: 120rpx;
  bottom: -44rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(255,255,255,.08);
}

.top-copy {
  width: 500rpx;
  position: relative;
  z-index: 1;
}

.top-title {
  font-size: 42rpx;
  font-weight: 900;
  margin-bottom: 30rpx;
}

.top-desc {
  font-size: 28rpx;
  line-height: 42rpx;
  opacity: .9;
}

.top-crown {
  position: absolute;
  right: 50rpx;
  bottom: 12rpx;
  width: 170rpx;
  height: 150rpx;
  z-index: 1;
}

.plan-card {
  position: relative;
  min-height: 250rpx;
  padding: 30rpx 34rpx;
  margin-bottom: 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 18rpx 52rpx rgba(46, 56, 96, .07);
}

.plan-card.selected {
  border-color: #6655ff;
  background: linear-gradient(135deg, #fff 0%, #fbfaff 100%);
  box-shadow: 0 18rpx 50rpx rgba(90, 75, 244, .1);
}

.plan-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.plan-name {
  color: #171923;
  font-size: 34rpx;
  font-weight: 900;
}

.plan-name.blue {
  color: #5a4bf4;
}

.tag {
  min-width: 92rpx;
  height: 52rpx;
  border-radius: 12rpx;
  background: #ffe7f1;
  color: #f33e83;
  font-size: 25rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 54rpx;
}

.tag.default {
  margin-right: 0;
}

.price-row {
  margin: 24rpx 0 22rpx;
  display: flex;
  align-items: baseline;
  color: #171923;
}

.yen {
  font-size: 38rpx;
  font-weight: 900;
}

.price {
  font-size: 66rpx;
  line-height: 1;
  font-weight: 900;
  letter-spacing: 0;
}

.period {
  color: #798296;
  font-size: 28rpx;
  margin-left: 10rpx;
}

.benefit {
  color: #737c91;
  font-size: 27rpx;
  line-height: 44rpx;
  display: flex;
  align-items: center;
}

.benefit text {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #5a4bf4;
  color: #fff;
  font-size: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
}

.radio {
  position: absolute;
  right: 34rpx;
  top: 58rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #a4adbf;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.radio.checked {
  background: #5a4bf4;
  border-color: #5a4bf4;
}

.upgrade-main {
  margin-top: 18rpx;
}

.packages-page {
  background:
    radial-gradient(circle at 18% 8%, rgba(97, 80, 244, .055), transparent 30%),
    linear-gradient(180deg, #fbfcff 0%, #ffffff 68%);
}

.top-card {
  height: 176rpx;
  margin-top: 24rpx;
  margin-bottom: 28rpx;
  border-radius: 20rpx;
  padding: 34rpx 34rpx 28rpx;
}

.top-title {
  font-size: 36rpx;
  margin-bottom: 18rpx;
}

.top-desc {
  font-size: 27rpx;
  line-height: 38rpx;
}

.top-crown {
  right: 42rpx;
  bottom: 8rpx;
  width: 144rpx;
  height: 128rpx;
}

.plan-card {
  min-height: 240rpx;
  border-radius: 20rpx;
  padding: 32rpx 34rpx;
  margin-bottom: 24rpx;
}

.plan-card.selected {
  box-shadow: 0 20rpx 50rpx rgba(90, 75, 244, .12);
}

.plan-name {
  font-size: 35rpx;
}

.price {
  font-size: 68rpx;
}

.benefit {
  font-size: 28rpx;
  line-height: 46rpx;
}

.radio {
  width: 48rpx;
  height: 48rpx;
}

.upgrade-main {
  height: 96rpx;
  border-radius: 18rpx;
  margin-top: 20rpx;
}
