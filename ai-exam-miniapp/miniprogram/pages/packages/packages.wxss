.packages-page { min-height: 100vh; background: #fff; padding-bottom: 40rpx; }
.top-card { height: 170rpx; border-radius: 18rpx; background: linear-gradient(135deg, #6852ff, #604ef2); color: #fff; padding: 32rpx 34rpx; display: flex; justify-content: space-between; overflow: hidden; margin: 22rpx 0 26rpx; }
.top-title { font-size: 34rpx; font-weight: 900; margin-bottom: 18rpx; }
.top-desc { font-size: 25rpx; line-height: 1.55; opacity: .95; }
.top-state { margin-top: 12rpx; font-size: 23rpx; opacity: .88; }
.top-crown { width: 166rpx; height: 126rpx; margin-top: 22rpx; }
.switch-row { height: 70rpx; border-radius: 36rpx; background: #f5f6fa; display: flex; align-items: center; padding: 5rpx; margin-bottom: 26rpx; }
.switch-item { flex: 1; height: 60rpx; border-radius: 30rpx; display: flex; align-items: center; justify-content: center; color: #767e90; font-size: 26rpx; font-weight: 700; }
.switch-item.active { background: linear-gradient(135deg, #6a55ff, #5548f0); color: #fff; }
.plan-card { position: relative; min-height: 214rpx; border: 2rpx solid #e6e8f1; border-radius: 18rpx; padding: 28rpx 34rpx; margin-bottom: 22rpx; background: #fff; }
.plan-card.selected { border-color: #6857ff; background: linear-gradient(135deg, #fff 0%, #f8f7ff 100%); }
.plan-head { display: flex; align-items: center; justify-content: space-between; }
.plan-name { font-size: 29rpx; font-weight: 900; color: #15151d; }
.plan-name.blue { color: #5a4bf4; }
.tag { background: #ffe7f2; color: #ff3f86; font-size: 23rpx; font-weight: 800; padding: 8rpx 18rpx; border-radius: 10rpx; margin-right: 52rpx; }
.price-row { margin: 18rpx 0 20rpx; display: flex; align-items: baseline; }
.price { font-size: 54rpx; color: #20222b; font-weight: 900; letter-spacing: 1rpx; }
.period { font-size: 26rpx; color: #4e5668; margin-left: 8rpx; }
.origin { font-size: 24rpx; color: #858b9a; text-decoration: line-through; margin-left: 18rpx; }
.benefits { font-size: 25rpx; color: #737b8d; line-height: 1.55; }
.section-label { font-size: 28rpx; font-weight: 900; color: #171922; margin: 30rpx 0 18rpx; }
.pack-card { min-height: 180rpx; }
.radio { position: absolute; right: 32rpx; top: 52rpx; width: 38rpx; height: 38rpx; border-radius: 50%; border: 3rpx solid #a4abb8; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 900; }
.radio.checked { background: #6251f2; border-color: #6251f2; }
.upgrade-main { margin-top: 24rpx; height: 86rpx; }
.agreement { text-align: center; color: #8c93a3; font-size: 23rpx; margin-top: 22rpx; }
.agreement text { color: #6251f2; }
