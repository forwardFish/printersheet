.more-page {
  background: #fbfcff;
}
.more-card,
.about {
  margin-top: 24rpx;
  padding: 0 28rpx;
}
.more-item {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #171923;
  font-size: 30rpx;
  font-weight: 800;
}
.line {
  height: 1rpx;
  background: #edf0f5;
}
.about {
  padding: 34rpx;
  text-align: center;
}
.about-logo {
  width: 120rpx;
  height: 120rpx;
}
.about-title {
  color: #171923;
  font-size: 32rpx;
  font-weight: 900;
  margin-top: 18rpx;
}
.about-desc {
  color: #7b8499;
  font-size: 25rpx;
  line-height: 38rpx;
  margin-top: 12rpx;
}
