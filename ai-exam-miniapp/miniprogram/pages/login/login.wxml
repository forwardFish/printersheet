<view class="login-page">
  <nav-bar title="AI出题小助手"></nav-bar>
  <view class="login-content">
    <image src="/assets/logo-distinctive.png" class="login-logo"></image>
    <view class="login-title">AI出题小助手</view>
    <view class="login-subtitle">登录后更好地使用全部功能</view>
    <button class="wechat-btn" bindtap="login">微信一键登录</button>
    <view class="agree-row" bindtap="toggleAgree">
      <view class="checkbox {{agreed ? 'checked' : ''}}">{{agreed ? '✓' : ''}}</view>
      <text>我已阅读并同意</text><text class="link">《用户协议》</text><text>和</text><text class="link">《隐私政策》</text>
    </view>
  </view>
</view>
