<view class="login-page">
  <nav-bar title="AI出题小助手"></nav-bar>
  <view class="login-hero">
    <image src="/assets/logo-distinctive.png" class="login-logo" mode="aspectFit"></image>
    <view class="login-title"><text>AI</text>出题小助手</view>
    <view class="login-subtitle">登录后更好地使用全部功能</view>
  </view>

  <view class="login-actions">
    <button class="wechat-btn" bindtap="login">
      <view class="wechat-icon">●●</view>
      <text>微信一键登录</text>
    </button>
    <view wx:if="{{mockLoginEnabled}}" class="mock-login" bindtap="mockLogin">本地模拟登录</view>
    <view class="agreement" bindtap="toggleAgree">
      <view class="checkbox {{agreed ? 'checked' : ''}}">{{agreed ? '✓' : ''}}</view>
      <text>我已阅读并同意</text>
      <text class="link">《用户协议》</text>
      <text>和</text>
      <text class="link">《隐私政策》</text>
    </view>
  </view>
</view>
