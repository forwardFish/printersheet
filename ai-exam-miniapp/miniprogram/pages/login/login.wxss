.login-page {
  min-height: 100vh;
  background: radial-gradient(circle at 50% 30%, #f2efff 0, #fbfcff 42%, #ffffff 100%);
  padding-bottom: 60rpx;
}

.login-hero {
  padding-top: 210rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-logo {
  width: 330rpx;
  height: 330rpx;
  margin-bottom: 62rpx;
  filter: drop-shadow(0 28rpx 48rpx rgba(103, 86, 244, .18));
}

.login-title {
  color: #171923;
  font-size: 62rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.login-title text {
  color: #5d4cf3;
  margin-right: 18rpx;
}

.login-subtitle {
  color: #7b8499;
  font-size: 32rpx;
  margin-top: 38rpx;
}

.login-actions {
  position: fixed;
  left: 76rpx;
  right: 76rpx;
  bottom: 95rpx;
}

.wechat-btn {
  width: 100%;
  height: 116rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #12c967, #05b95a);
  color: #fff;
  font-size: 36rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 34rpx rgba(0, 181, 92, .22);
}

.wechat-icon {
  width: 66rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
  color: #fff;
  letter-spacing: -10rpx;
}

.mock-login {
  color: #6c7488;
  font-size: 24rpx;
  text-align: center;
  margin-top: 22rpx;
}

.agreement {
  margin-top: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  color: #737c91;
  font-size: 26rpx;
  line-height: 42rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  border: 3rpx solid #8f98aa;
  margin-right: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 22rpx;
}

.checkbox.checked {
  background: #5a4bf4;
  border-color: #5a4bf4;
}

.link {
  color: #4f46e5;
  margin: 0 4rpx;
}

.login-page {
  background:
    radial-gradient(circle at 50% 30%, rgba(106, 89, 244, .12), transparent 34%),
    radial-gradient(circle at 24% 18%, rgba(255, 255, 255, .95), transparent 28%),
    linear-gradient(180deg, #fbfcff 0%, #ffffff 72%);
}

.login-hero {
  padding-top: 196rpx;
}

.login-logo {
  width: 350rpx;
  height: 350rpx;
  margin-bottom: 64rpx;
}

.login-title {
  font-size: 64rpx;
  line-height: 78rpx;
}

.login-subtitle {
  font-size: 33rpx;
  margin-top: 34rpx;
}

.login-actions {
  left: 74rpx;
  right: 74rpx;
  bottom: 96rpx;
}

.wechat-btn {
  height: 118rpx;
  border-radius: 22rpx;
}

.agreement {
  margin-top: 54rpx;
  font-size: 27rpx;
}
