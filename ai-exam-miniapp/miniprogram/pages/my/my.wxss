    radial-gradient(circle at 49% 112%, rgba(255,255,255,.13), transparent 30%),
    radial-gradient(circle at 94% 80%, rgba(255,255,255,.16), transparent 22%),
    linear-gradient(135deg, #725cff 0%, #5849f0 100%);
  box-shadow: 0 20rpx 44rpx rgba(84, 71, 238, .18);
}

.points-card::before,
.points-card::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, .16);
}

.points-card::before {
  right: 54rpx;
  bottom: -24rpx;
  width: 112rpx;
  height: 52rpx;
  transform: rotate(-18deg);
}

.points-card::after {
  right: 18rpx;
  bottom: -18rpx;
  width: 102rpx;
  height: 46rpx;
  transform: rotate(20deg);
}

.points-label {
  font-size: 29rpx;
}

.points-num {
  font-size: 66rpx;
  margin-top: 16rpx;
}

