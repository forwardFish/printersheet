  background:
    radial-gradient(circle at 96% 0%, rgba(105, 86, 244, .13), transparent 34%),
    linear-gradient(180deg, #ffffff 0%, #fbfbff 100%);
  border-color: #e7e9f6;
  box-shadow: 0 18rpx 48rpx rgba(44, 55, 96, .07);
  overflow: hidden;
  position: relative;
}

.share-card::before {
  content: '';
  position: absolute;
  right: -54rpx;
  top: -74rpx;
  width: 184rpx;
  height: 184rpx;
  border-radius: 50%;
  background: rgba(103, 84, 244, .08);
}

.share-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.share-eyebrow {
  color: #6a5af4;
  font-size: 24rpx;
  line-height: 30rpx;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.share-title {
  color: #171923;
  font-size: 38rpx;
  line-height: 48rpx;
  font-weight: 900;
}

.share-badge {
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #fff5db;
  color: #d67900;
  border: 1rpx solid #ffe1a8;
  font-size: 23rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
}

.share-desc {
  color: #778196;
  font-size: 27rpx;
  line-height: 40rpx;
  margin: 18rpx 0 24rpx;
  position: relative;
  z-index: 1;
}

.reward-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-bottom: 22rpx;
  position: relative;
  z-index: 1;
}

.reward-item {
  min-height: 108rpx;
  border-radius: 18rpx;
  background: #f6f5ff;
  border: 1rpx solid #ebe8ff;
  padding: 20rpx 22rpx;
}

.reward-num {
  color: #5a4bf4;
  font-size: 42rpx;
  line-height: 46rpx;
  font-weight: 900;
}

.reward-copy {
  color: #6f7890;
  font-size: 24rpx;
  line-height: 30rpx;
  margin-top: 6rpx;
}

.share-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  position: relative;
  z-index: 1;
}

.share-btn {
  height: 78rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
}

.share-btn.reward {
  background: linear-gradient(135deg, #6d58ff 0%, #5146ee 100%);
  color: #fff;
  box-shadow: 0 14rpx 28rpx rgba(83, 69, 238, .22);
}

.share-btn.reward::before {
  content: '↗';
  margin-right: 12rpx;
  font-size: 30rpx;
  line-height: 1;
}

.share-btn.poster {
  margin-top: 0;
  background: #ffffff;
  color: #5a4bf4;
  border: 1rpx solid #ddd9ff;
}

.share-btn.poster::before {
  content: '◎';
  margin-right: 10rpx;
  font-size: 25rpx;
}

.invite-link {
  height: 74rpx;
  margin-top: 18rpx;
  border-radius: 18rpx;
  border: 2rpx dashed #b9b1ff;
  color: #5a4bf4;
  background: rgba(255, 255, 255, .7);
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.invite-link::before {
  content: '↗';
  margin-right: 12rpx;
  font-size: 28rpx;
  transform: rotate(45deg);
}

.share-status {
  margin-top: 16rpx;
  color: #5a4bf4;
  font-size: 24rpx;
  line-height: 32rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}
