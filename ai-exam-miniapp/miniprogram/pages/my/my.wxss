.my-page {
  background: radial-gradient(circle at 72% 8%, #f0efff 0, #fbfcff 32%, #ffffff 100%);
}

.my-container {
  padding-top: 34rpx;
}

.user-box {
  height: 170rpx;
  display: flex;
  align-items: center;
}

.avatar {
  width: 118rpx;
  height: 118rpx;
  border-radius: 50%;
  border: 8rpx solid #fff;
  box-shadow: 0 12rpx 28rpx rgba(110, 96, 190, .16);
  margin-right: 40rpx;
  background: #ddd8ec;
}

.nickname {
  color: #171923;
  font-size: 42rpx;
  font-weight: 900;
}

.uid {
  color: #7b8499;
  font-size: 28rpx;
  line-height: 40rpx;
  margin-top: 18rpx;
  max-width: 520rpx;
}

.copy-mark {
  margin-left: 12rpx;
  color: #555d6f;
}

.member-card {
  min-height: 218rpx;
  margin-top: 30rpx;
  border-radius: 18rpx;
  border: 1rpx solid #f2bc5f;
  background: linear-gradient(135deg, #fff9ed 0%, #fffefb 62%, #fff3d5 100%);
  display: flex;
  align-items: flex-start;
  padding: 36rpx 32rpx 26rpx;
  position: relative;
  overflow: hidden;
}

.member-card::after {
  content: '';
  position: absolute;
  right: 8rpx;
  bottom: -30rpx;
  width: 180rpx;
  height: 140rpx;
  background: rgba(242, 174, 51, .12);
  border-radius: 80rpx 80rpx 0 0;
}

.member-crown {
  width: 82rpx;
  height: 82rpx;
  margin: 40rpx 32rpx 0 0;
  z-index: 1;
}

.member-info {
  flex: 1;
  z-index: 1;
}

.member-title {
  color: #171923;
  font-size: 44rpx;
  font-weight: 900;
}

.member-date,
.member-tip {
  color: #9a762e;
  font-size: 25rpx;
  line-height: 36rpx;
  margin-top: 12rpx;
  width: 280rpx;
}

.check-btn {
  position: absolute;
  right: 34rpx;
  top: 76rpx;
  width: 190rpx;
  height: 66rpx;
  border-radius: 14rpx;
  border: 1rpx solid #efa63a;
  color: #d87900;
  font-size: 28rpx;
  font-weight: 900;
  z-index: 1;
}

.points-card {
  height: 154rpx;
  margin-top: 28rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #6f59ff 0%, #5548ef 100%);
  padding: 28rpx 38rpx;
  color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  overflow: hidden;
  position: relative;
}

.points-label {
  font-size: 28rpx;
  font-weight: 800;
}

.points-num {
  font-size: 62rpx;
  line-height: 1;
  font-weight: 900;
  margin-top: 18rpx;
}

.points-num text {
  font-size: 30rpx;
}

.buy-btn {
  width: 286rpx;
  height: 70rpx;
  border-radius: 14rpx;
  background: #fff;
  color: #5a4bf4;
  font-size: 30rpx;
  font-weight: 900;
}

.share-card {
  margin-top: 28rpx;
  padding: 34rpx 32rpx;
}

.share-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #171923;
}

.share-desc {
  color: #737c91;
  font-size: 28rpx;
  line-height: 44rpx;
  margin: 18rpx 0 30rpx;
}

.share-btn {
  width: 100%;
  height: 78rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #6b55ff, #5548ef);
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-btn.poster {
  margin-top: 18rpx;
  background: linear-gradient(135deg, #f7f6ff, #efecff);
  color: #5a4bf4;
  border: 1rpx solid #ddd8ff;
  box-shadow: none;
}

.share-btn text {
  margin-right: 14rpx;
}

.invite-link {
  height: 74rpx;
  border-radius: 14rpx;
  border: 2rpx dashed #aaa2ff;
  color: #5a4bf4;
  font-size: 29rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
}

.invite-link text {
  margin-right: 12rpx;
}

.share-status {
  color: #5a4bf4;
  margin-top: 16rpx;
  text-align: center;
  font-size: 24rpx;
}

.list-card {
  margin-top: 28rpx;
  padding: 0 34rpx;
}

.list-item {
  height: 116rpx;
  display: flex;
  align-items: center;
  color: #171923;
  font-size: 34rpx;
  font-weight: 900;
}

.line {
  height: 1rpx;
  background: #edf0f5;
  margin-left: 88rpx;
}

.list-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #6b55ff, #5046ea);
  margin-right: 34rpx;
  position: relative;
}

.list-icon.doc::after {
  content: '';
  position: absolute;
  left: 19rpx;
  top: 14rpx;
  width: 18rpx;
  height: 26rpx;
  border-radius: 3rpx;
  background: #fff;
}

.list-icon.bag::after {
  content: '';
  position: absolute;
  left: 15rpx;
  top: 18rpx;
  width: 26rpx;
  height: 23rpx;
  border-radius: 6rpx;
  border: 4rpx solid #fff;
  border-top: 0;
}

.chev {
  margin-left: auto;
  color: #7f8798;
  font-size: 52rpx;
  font-weight: 400;
}

.share-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(31, 38, 58, .58);
  z-index: 80;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-dialog {
  width: 562rpx;
  min-height: 600rpx;
  border-radius: 24rpx;
  background: #fff;
  overflow: hidden;
  box-shadow: 0 28rpx 80rpx rgba(0,0,0,.18);
}

.send-title {
  padding: 44rpx 42rpx 24rpx;
  color: #171923;
  font-size: 32rpx;
  font-weight: 900;
}

.friend-row {
  display: flex;
  align-items: center;
  padding: 0 42rpx 30rpx;
}

.friend-avatar {
  width: 84rpx;
  height: 84rpx;
  background: linear-gradient(135deg, #eeeeee, #d9d9d9);
  margin-right: 24rpx;
  position: relative;
}

.friend-avatar::after {
  content: '';
  position: absolute;
  left: 24rpx;
  top: 20rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #fff;
}

.friend-name {
  color: #171923;
  font-size: 30rpx;
  font-weight: 900;
}

.mini-card {
  width: 230rpx;
  height: 242rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e1e4ec;
  margin: 0 auto 34rpx;
  padding: 22rpx;
}

.mini-title {
  text-align: center;
  color: #171923;
  font-size: 28rpx;
  font-weight: 900;
  margin-bottom: 18rpx;
}

.mini-shot {
  width: 120rpx;
  height: 120rpx;
  display: block;
  margin: 0 auto;
  border-radius: 4rpx;
}

.mini-type {
  color: #7a8396;
  font-size: 28rpx;
  font-weight: 900;
  margin-top: 16rpx;
}

.dialog-actions {
  height: 96rpx;
  border-top: 1rpx solid #e7e9ef;
  display: flex;
}

.dialog-actions view {
  width: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #171923;
  font-size: 30rpx;
  font-weight: 900;
}

.dialog-actions .send {
  color: #5a4bf4;
  border-left: 1rpx solid #e7e9ef;
}

.my-page {
  background:
    radial-gradient(circle at 20% 8%, rgba(99, 80, 244, .07), transparent 31%),
    radial-gradient(circle at 88% 16%, rgba(255, 221, 145, .12), transparent 24%),
    linear-gradient(180deg, #fbfcff 0%, #ffffff 64%);
}

