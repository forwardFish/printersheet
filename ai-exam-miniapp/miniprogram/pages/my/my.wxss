  height: 160rpx;
  border-radius: 96rpx 96rpx 0 0;
  background:
    radial-gradient(circle at 50% 18%, rgba(242, 174, 51, .22) 0 10rpx, transparent 12rpx),
    linear-gradient(135deg, rgba(242, 174, 51, .12), rgba(242, 174, 51, .04));
