page {
  min-height: 100vh;
  background: #f8f9ff;
  color: #171923;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
}

view, text, button, input, textarea, image, scroll-view {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  border: 0;
  line-height: normal;
  background: transparent;
  font: inherit;
}

button::after {
  border: none;
}

.safe-page {
  min-height: 100vh;
  padding-bottom: 170rpx;
  background: radial-gradient(circle at 18% 6%, #fbfbff 0, #f7f8ff 26%, #ffffff 68%);
}

.container {
  padding: 0 32rpx;
}

.card {
  border-radius: 24rpx;
  background: rgba(255, 255, 255, .96);
  border: 1rpx solid #e8ebf4;
  box-shadow: 0 18rpx 52rpx rgba(50, 60, 105, .07);
}

.primary-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #6b55ff 0%, #4d45ef 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 34rpx rgba(88, 72, 242, .22);
}

.primary-btn.disabled {
  opacity: .55;
}

.subtle-text {
  color: #7a8398;
}

.purple {
  color: #5b4cf3;
}

.gradient-purple {
  background: linear-gradient(135deg, #6b55ff 0%, #5548f0 100%);
}

.icon-surface {
  background: linear-gradient(135deg, #755cff 0%, #5046ea 100%);
  box-shadow: inset 0 -8rpx 14rpx rgba(47, 38, 176, .16), 0 10rpx 18rpx rgba(84, 70, 240, .2);
}

.visual-page {
  background:
    radial-gradient(circle at 16% 8%, rgba(116, 97, 255, .08), transparent 30%),
    radial-gradient(circle at 86% 18%, rgba(255, 210, 116, .10), transparent 24%),
    linear-gradient(180deg, #fbfcff 0%, #ffffff 64%);
}

.card {
  border-color: #e7eaf3;
  box-shadow: 0 18rpx 56rpx rgba(47, 58, 100, .065);
}
