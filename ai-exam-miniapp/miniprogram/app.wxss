page {
  min-height: 100vh;
  background: #ffffff;
  color: #15151d;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
}
view, text, button, input, textarea, image {
  box-sizing: border-box;
}
button {
  padding: 0;
  margin: 0;
  border: 0;
  line-height: normal;
  background: transparent;
  font: inherit;
}
button::after { border: none; }
.safe-page {
  min-height: 100vh;
  padding-bottom: 148rpx;
  background: #fff;
}
.container {
  padding: 0 34rpx;
}
.card {
  border-radius: 24rpx;
  background: #fff;
  border: 1rpx solid #edf0f7;
  box-shadow: 0 10rpx 36rpx rgba(61, 72, 120, .06);
}
.primary-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #6346f4 0%, #4c40ef 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 24rpx rgba(87, 68, 242, .22);
}
.primary-btn.disabled {
  opacity: .55;
}
.subtle-text {
  color: #7e8699;
}
.gradient-purple {
  background: linear-gradient(135deg, #6b55ff 0%, #5548f0 100%);
}
