PORT=8787
PUBLIC_BASE_URL=http://127.0.0.1:8787

# 当前激活的大模型供应商。内置：deepseek、openaiCompatible
AI_PROVIDER=deepseek

# 推荐统一用 AI_* 覆盖当前供应商，方便横向测试多个模型。
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-pro

# 兼容 DeepSeek 专用变量；如果 AI_* 为空，会读取这些变量。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# true 时才允许使用内置 demo/mock。真实验收时必须 false 或不设置。
AI_MOCK_MODE=false

# true 时真实模型失败后才允许 fallback 到 mock。真实验收时必须 false 或不设置。
AI_FALLBACK_TO_MOCK=false

# 可选：PDF 中文字体。如果不设置，程序会尝试系统常见路径。
# PDF_FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc
